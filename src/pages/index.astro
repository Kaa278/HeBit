      <!-- CARA ORDER -->
      <section id="cara-order" class="section" style="padding-top:0" aria-labelledby="order-title">
        <div class="container">
          <p class="kicker">Cara Order</p>
          <h2 id="order-title" class="sec-title">Checkout sesimple chat admin.</h2>
          <p class="sec-sub">Tidak perlu akun, cart, atau form panjang. Semua proses lanjut manual lewat WhatsApp agar cepat dan fleksibel.</p>

          <div class="steps-grid">
            <article class="step-card">
              <div class="step-num">01</div>
              <h3 class="step-title">Pilih Paket</h3>
              <p class="step-desc">Pilih paket harian, mingguan, atau bulanan dari katalog sesuai kebutuhan kamu.</p>
            </article>
            <article class="step-card">
              <div class="step-num">02</div>
