    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <small class="footer-copy">© {new Date().getFullYear()} HeBit. Katalog API & produk digital.</small>
        <a class="footer-link" href="#produk">Kembali ke katalog</a>
      </div>
    </footer>

    <script>
      // ── Quick Start interaction logic ──
      (() => {
        const tabs = Array.from(document.querySelectorAll('.qs-tab')) as HTMLButtonElement[];
        const panels = Array.from(document.querySelectorAll('.qs-content')) as HTMLDivElement[];
        const copyButtons = Array.from(document.querySelectorAll('.qs-copy')) as HTMLButtonElement[];

        if (tabs.length && panels.length) {
          const userAgent = navigator.userAgent;
          let defaultOs = 'linux';
          if (userAgent.includes('Win')) defaultOs = 'windows';
          else if (userAgent.includes('Mac')) defaultOs = 'mac';

          const setActiveTab = (os: string) => {
            tabs.forEach((tab) => {
              const isActive = tab.dataset.os === os;
              tab.classList.toggle('active', isActive);
              tab.setAttribute('aria-selected', String(isActive));
            });
            panels.forEach((panel) => {
              const shouldShow = panel.id === `qs-${os}`;
              panel.classList.toggle('active', shouldShow);
              panel.setAttribute('aria-hidden', String(!shouldShow));
            });
          };

          setActiveTab(defaultOs);

          tabs.forEach((tab) => {
            tab.addEventListener('click', () => {
              const os = tab.dataset.os || 'linux';
              setActiveTab(os);
            });
          });
        }

        copyButtons.forEach((btn) => {
          const originalLabel = btn.textContent || 'Copy';
          btn.addEventListener('click', async () => {
            const copyText = btn.dataset.copy || '';
            if (!copyText) return;
            try {
              await navigator.clipboard.writeText(copyText);
              btn.textContent = 'Copied!';
              btn.disabled = true;
              setTimeout(() => {
                btn.textContent = originalLabel;
                btn.disabled = false;
              }, 2000);
            } catch {
              btn.textContent = 'Failed';
              setTimeout(() => { btn.textContent = originalLabel; }, 2000);
            }
          });
        });
      })();

      // ── Playground live API logic ──
      const PLAYGROUND_API_URL = "/api/chat";
      const TRIAL_KEY = "hebit_trial_remaining";
      const TRIAL_MAX = 3;

      function getTrialLeft() {
        const stored = localStorage.getItem(TRIAL_KEY);
        if (stored === null) {
          localStorage.setItem(TRIAL_KEY, String(TRIAL_MAX));
          return TRIAL_MAX;
        }

        const parsed = parseInt(stored, 10);
        if (Number.isNaN(parsed)) {
          localStorage.setItem(TRIAL_KEY, String(TRIAL_MAX));
          return TRIAL_MAX;
        }

        return Math.min(TRIAL_MAX, Math.max(0, parsed));
      }

      function decrementTrial() {
        const current = getTrialLeft();
        const next = Math.max(0, current - 1);
        localStorage.setItem(TRIAL_KEY, String(next));
        return next;
      }

      let trialLeft = getTrialLeft();

      const inputEl    = document.getElementById('pg-input')    as HTMLTextAreaElement;
      const resultEl   = document.getElementById('pg-result')   as HTMLDivElement;
      const remainEl   = document.getElementById('pg-remaining') as HTMLSpanElement;
      const runBtn     = document.getElementById('pg-run')       as HTMLButtonElement;
      const modelEl    = document.getElementById('pg-model')     as HTMLSelectElement;
      if (remainEl) remainEl.textContent = String(trialLeft);

      runBtn?.addEventListener('click', async () => {
        const prompt = inputEl?.value?.trim();
        if (!prompt) {
          resultEl.textContent = 'Tulis prompt dulu ya sebelum klik Run.';
          resultEl.className = 'pg-result error';
          return;
        }
        if (trialLeft <= 0) {
          resultEl.textContent = 'Trial habis. Ambil trial key via WhatsApp untuk 20 request gratis, atau langsung beli paket!';
          resultEl.className = 'pg-result error';
          return;
        }

        resultEl.textContent = 'Memproses...';
        resultEl.className = 'pg-result loading';
        runBtn.disabled = true;

        try {
          const selectedModelLabel = modelEl?.selectedOptions?.[0]?.textContent?.trim() || "Llama 3.3 70B (Fast)";
          const res = await fetch(PLAYGROUND_API_URL, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ prompt, displayModel: selectedModelLabel }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data?.error?.message || data?.error || "API error");

          trialLeft = decrementTrial();
          remainEl.textContent = String(trialLeft);
          resultEl.textContent = data.choices?.[0]?.message?.content ?? "Tidak ada respons.";
          resultEl.className = "pg-result";
        } catch (err) {
          const message = err instanceof Error ? err.message : "Unknown error";
          resultEl.textContent = "Gagal: " + message;
          resultEl.className = "pg-result error";
        } finally {
          runBtn.disabled = false;
        }
      });
      (function() {
        const ALL_MODELS = [
          "cx/gpt-5.5-xhigh","cx/gpt-5.5-high","cx/gpt-5.5-medium","cx/gpt-5.5-low",
          "cx/gpt-5.4","cx/gpt-5.4-mini","cx/gpt-5.3-codex-spark","cx/gpt-5.3-codex",
          "cx/gpt-5.2","cx/gpt-5.5",
          "antigravity/claude-opus-4-6-thinking","antigravity/claude-sonnet-4-6",
          "antigravity/gemini-3-pro-preview","antigravity/gemini-3.1-pro-low",
          "antigravity/gemini-3-flash-preview","antigravity/gpt-oss-120b-medium",
          "antigravity/gemini-3-pro-image-preview","antigravity/gemini-3.1-flash-image",
          "antigravity/gemini-2.5-computer-use-preview-10-2025",
          "kiro/claude-opus-4.7","kiro/claude-opus-4.6","kiro/claude-sonnet-4.6",
          "kiro/claude-sonnet-4.5","kiro/claude-haiku-4.5",
          "groq/llama-3.3-70b-versatile",
          "groq/meta-llama/llama-4-maverick-17b-128e-instruct",
          "groq/qwen/qwen3-32b","groq/openai/gpt-oss-120b",
          "nvidia/z-ai/glm-5.1","nvidia/minimaxai/minimax-m2.7",
          "nvidia/google/gemma-4-31b-it","nvidia/mistralai/mistral-small-4-119b-2603",
          "nvidia/mistralai/mistral-large-3-675b-instruct-2512",
          "nvidia/mistralai/devstral-2-123b-instruct-2512",
          "nvidia/qwen/qwen3.5-397b-a17b","nvidia/qwen/qwen3.5-122b-a10b",
          "nvidia/stepfun-ai/step-3.5-flash","nvidia/deepseek-ai/deepseek-v4-pro",
          "nvidia/openai/gpt-oss-120b","nvidia/openai/gpt-oss-20b",
          "nvidia/nvidia/nemotron-3-super-120b-a12b",
          "sumopod/minimaxai/minimax-m2.7",
          "nvidia/nv-embedqa-e5-v5","nvidia/nv-rerankqa-mistral-4b-v3",
          "groq/whisper-large-v3","groq/whisper-large-v3-turbo",
          "groq/distil-whisper-large-v3-en",
          "nvidia/parakeet-ctc-1.1b-asr","nvidia/fastpitch","nvidia/tacotron2",
        ];

        const PROVIDER_COLORS: Record<string, string> = {
          cx:          "#6366f1",
          codex:       "#6366f1",
          antigravity: "#4285F4",
          kiro:        "#7c3aed",
          groq:        "#f97316",
          nvidia:      "#22c55e",
          sumopod:     "#06b6d4",
        };

        function getDisplayName(id: string): string {
          const raw = id.split("/").pop() || id;
          const normalized = raw
            .replace(/[_-]+/g, " ")
            .replace(/\s+/g, " ")
            .trim();

          const labelMap: Record<string, string> = {
            ai: "AI",
            api: "API",
            asr: "ASR",
            ctc: "CTC",
            e5: "E5",
            glm: "GLM",
            gpt: "GPT",
            it: "IT",
            nv: "NV",
            oss: "OSS",
            qa: "QA",
          };

          return normalized
            .split(" ")
            .map((word) => {
              const lower = word.toLowerCase();
              if (labelMap[lower]) return labelMap[lower];
              if (/^[a-z]+\d+(\.\d+)?$/i.test(word)) return word.replace(/^[a-z]+/, (prefix) => labelMap[prefix.toLowerCase()] || prefix.charAt(0).toUpperCase() + prefix.slice(1));
              if (/^\d+[a-z]+$/i.test(word)) return word.toUpperCase();
              return word.charAt(0).toUpperCase() + word.slice(1);
            })
            .join(" ");
        }

        function getProvider(id: string): string {
          return id.split("/")[0];
        }

        function getFilter(id: string): string {
          const name = id.toLowerCase();
          if (name.includes("gpt") || name.includes("codex")) return "gpt";
          if (name.includes("claude")) return "claude";
          if (name.includes("gemini")) return "gemini";
          if (name.includes("llama")) return "llama";
          if (name.includes("deepseek")) return "deepseek";
          if (name.includes("qwen")) return "qwen";
          return "lainnya";
        }

        function renderModels(filter: string, search: string): void {
          const list = document.getElementById("model-list") as HTMLDivElement | null;
          const empty = document.getElementById("model-empty") as HTMLDivElement | null;
          if (!list || !empty) return;

          const filtered = ALL_MODELS.filter((id) => {
            const name = getDisplayName(id).toLowerCase();
            const matchFilter = filter === "all" || getFilter(id) === filter;
            const q = search.toLowerCase();
            const matchSearch = !search || name.includes(q) || id.toLowerCase().includes(q);
            return matchFilter && matchSearch;
          });

          list.innerHTML = "";
          if (filtered.length === 0) {
            empty.style.display = "block";
            list.style.display = "none";
            return;
          }
          empty.style.display = "none";
          list.style.display = "grid";

          filtered.forEach((id) => {
            const provider = getProvider(id);
            const color = PROVIDER_COLORS[provider] || "#6e6c82";
            const displayName = getDisplayName(id);
            const div = document.createElement("div");
            div.className = "model-item";
            div.setAttribute("role", "listitem");
            div.innerHTML = `
              <span class="model-dot" style="background:${color}"></span>
              <span class="model-name">${displayName}</span>
            `;
            list.appendChild(div);
          });
        }

        let currentFilter = "all";
        let currentSearch = "";

        document.addEventListener("DOMContentLoaded", () => {
          renderModels(currentFilter, currentSearch);

          document.getElementById("model-search")?.addEventListener("input", (e) => {
            const target = e.target as HTMLInputElement | null;
            currentSearch = target?.value || "";
            renderModels(currentFilter, currentSearch);
          });

          document.querySelectorAll(".mpill").forEach((btn) => {
            btn.addEventListener("click", () => {
              document.querySelectorAll(".mpill").forEach((b) => b.classList.remove("active"));
              btn.classList.add("active");
              const button = btn as HTMLButtonElement;
              currentFilter = button.dataset.filter || "all";
              renderModels(currentFilter, currentSearch);
            });
          });
        });
      })();
    </script>

  </body>
</html>