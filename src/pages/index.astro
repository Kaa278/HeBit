      <!-- BENEFIT -->
      <section id="trust" class="section" style="padding-top:0" aria-labelledby="trust-title">
        <div class="container">
          <div class="trust-shell">
            <div class="trust-inner">
              <div>
                <p class="kicker">Benefit</p>
                <h2 id="trust-title" class="sec-title" style="max-width:13ch">Kenapa order lewat HeBit?</h2>
                <p class="sec-sub">Informasi paket jelas, CTA cepat, dan proses order minim friction.</p>
